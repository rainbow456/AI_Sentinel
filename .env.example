# ── AI Sentinel Environment Variables ──────────────────────────────────────
# Variables marked [Gateway] are for the security gateway module.
# Variables marked [Analyst] are for the analyst/agent module.
# Variables marked [CRM] are for the CMS Agent module.
# Variables marked [Shared] are used by multiple modules.
#
# ┌─ Field Annotation Legend ────────────────────────────────────────────────┐
# │ REQUIRED    Must be filled/validated for your environment after cloning the code (connection failures usually stem from incorrect values here) │
# │ OPTIONAL    May be left blank; empty value disables the corresponding feature without breaking core workflows │
# │ DEFAULT OK  Retain the preset value; modification is generally unnecessary │
# └────────────────────────────────────────────────────────────────────────┘
#
# ⚠️ Important: When launching via start_all.bat / start_all.ps1, identical variables hardcoded in the scripts
#    will override values in this file (load_dotenv does not overwrite pre-existing environment variables).
#    If you use these startup scripts, update the matching values inside the scripts accordingly;
#    This file serves as the sole configuration source ONLY when launching directly with
#    `python -m gateway.main` / `python -m analyst.ui.app`.

# ═══════════════════════════════════════════════════════════════════════════════
# Shared
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_ID=gateway-01          # DEFAULT OK Gateway instance identifier
LLM_PROVIDER=deepseek
NO_PROXY=localhost,127.0.0.1   # DEFAULT OK Bypass system proxy for local addresses
PYTHONUNBUFFERED=1             # DEFAULT OK Enable real-time log streaming

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: Splunk HEC (event emission) — Gateway writes security events to Splunk
# ═══════════════════════════════════════════════════════════════════════════════
# Both URL and TOKEN must be valid for event forwarding to activate; if either is missing, logs are only printed to stdout (fail-soft mode).
# Scheme note: Use http:// if HEC listens on HTTP, use https:// with VERIFY=0 for self-signed HTTPS certificates.
# REQUIRED HEC endpoint URL, set to your Splunk host/port/protocol, example: http://localhost:8088/services/collector
SPLUNK_HEC_URL="http://localhost:8088/services/collector"
# REQUIRED HEC token — Must match the token configured in Splunk Data Inputs → HTTP Event Collector
SPLUNK_HEC_TOKEN="b122039b-0000000000000000000003"
SPLUNK_HEC_VERIFY=0            # DEFAULT OK 1 = validate TLS certificates, set to 0 to skip validation for self-signed certs
SPLUNK_HEC_INDEX=main          # DEFAULT OK Target index for gateway events; must match SPLUNK_DEFAULT_INDEX under Analyst section below
# OPTIONAL SPLUNK_HEC_CHANNEL: Only required if Index Acknowledgment is enabled on the token; auto-generated if blank
SPLUNK_HEC_CHANNEL=

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM Proxy (/v1/chat/completions)
# ═══════════════════════════════════════════════════════════════════════════════
# Fill both fields to proxy /v1/chat/completions requests to a real OpenAI-compatible backend; leave blank to enable mock mode.
# OPTIONAL Upstream LLM endpoint and API key; blank value enables mock mode
OPENAI_UPSTREAM_URL=
OPENAI_UPSTREAM_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM Semantic Detection (Secondary Judgement Layer) — Fill semantic blind spots left by regex/keyword rules via Claude
# ═══════════════════════════════════════════════════════════════════════════════
# Claude is only invoked when rule layers produce ambiguous grey-area matches, to interpret true user intent
# and catch semantic attacks missed by static rules: semantic jailbreaks, indirect injection, subtle prompt manipulation, multi-stage progressive exploits.
# High-risk requests clearly blocked by static rules skip LLM calls to reduce latency and API costs;
# all LLM timeouts/failbacks revert to judgements from the static rule engine.
#
# Requirement note: When LLM_DETECT_ENABLED=1, ANTHROPIC_API_KEY becomes REQUIRED to activate the semantic detection layer.
#    The gateway will launch without errors if blank, but semantic analysis will be disabled (a warning log will print on startup).
LLM_DETECT_ENABLED=1           # DEFAULT OK 1 = enable semantic layer; 0 = disable (the key below is irrelevant when disabled)
# CONDITIONALLY REQUIRED Claude API Key — Only used when LLM_PROVIDER=anthropic; ignored for deepseek deployments
ANTHROPIC_API_KEY=
LLM_DETECT_MODEL=deepseek-chat
LLM_DETECT_TIMEOUT=8           # DEFAULT OK Timeout in seconds for single judgement requests; falls back to static rules on timeout
LLM_DETECT_MAX_CHARS=6000      # DEFAULT OK Truncation limit for submitted text to control latency and API expenses
LLM_DETECT_CACHE_TTL=300       # DEFAULT OK Cache lifetime in seconds for judgements of identical inputs, deduplicates API calls to cut costs
# OPTIONAL 1 = allow semantic layer to suppress low-risk false positives (e.g. high-entropy random strings); default 0 (only escalate risks, safer stance)
LLM_DETECT_ALLOW_DEESCALATE=0
# OPTIONAL ANTHROPIC_BASE_URL: Override default Claude endpoint for self-hosted instances/proxies; blank uses official api.anthropic.com
ANTHROPIC_BASE_URL=

# ── Domestic DeepSeek (or other OpenAI-compatible providers) — Used when LLM_PROVIDER=deepseek/openai ──
# DeepSeek implements OpenAI-compatible protocol (/chat/completions + Bearer auth + JSON mode) with direct domestic connectivity.
# Shared configuration for both gateway semantic detection and Analyst NL-to-SPL translation modules.
# REQUIRED DeepSeek API Key (applied at platform.deepseek.com, format sk-...)
LLM_API_KEY=sk-00000000000000000000000000000
# DEFAULT OK OpenAI-compatible endpoint; default value https://api.deepseek.com applies if blank
LLM_BASE_URL=https://api.deepseek.com

# ── Analyst-side LLM (NL-to-SPL / Intent Classification) — Reuses the ANTHROPIC_API_KEY defined above ──────────
# Analyst natural language input box translates plain queries like "all blocked injection attempts from yesterday" into valid SPL, and classifies user command intent.
# Automatically activates if ANTHROPIC_API_KEY exists; silently falls back to keyword heuristic matching without throwing errors if missing.
# OPTIONAL ANALYST_LLM_MODEL: Inherits LLM_DETECT_MODEL if blank (haiku recommended for low-latency interaction);
#         defaults to claude-opus-4-8 if both fields empty. Retain haiku for interactive query workflows.
ANALYST_LLM_MODEL=deepseek-chat
ANALYST_LLM_TIMEOUT=8          # DEFAULT OK Timeout in seconds for single NL-to-SPL / intent classification calls

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk Search (REST API — reading events) — Analyst pulls event data from this endpoint
# ═══════════════════════════════════════════════════════════════════════════════
# Splunk management port 8089 uses HTTPS (self-signed certs) by default. Connection failures mostly stem from incorrect HOST, credentials or USE_SSL flag.
SPLUNK_HOST=127.0.0.1          # REQUIRED Splunk host address; replace with public IP/domain for remote deployments
SPLUNK_PORT=8089               # REQUIRED Splunk REST management port, confirm before deployment
SPLUNK_USERNAME=admin          # REQUIRED Splunk login username
SPLUNK_PASSWORD=xxxxxxxxx      # REQUIRED Splunk login password (update to your own credentials)
# OPTIONAL SPLUNK_TOKEN: Fill for Bearer token authentication; leave blank if using username/password login
SPLUNK_TOKEN=
SPLUNK_USE_REAL=true           # DEFAULT OK true = connect to live Splunk instance; false = load mock sample data
SPLUNK_USE_SSL=true            # REQUIRED Set true for HTTPS port 8089, set false for plain HTTP
SPLUNK_VERIFY_SSL=false        # DEFAULT OK Set false to skip TLS validation for self-signed certificates
SPLUNK_DEFAULT_INDEX=main      # DEFAULT OK Target index for Analyst queries; must match SPLUNK_HEC_INDEX in the Gateway section above
SPLUNK_DEFAULT_EARLIEST=-30d   # DEFAULT OK Default time range for search queries
SPLUNK_MAX_RESULTS=1000        # DEFAULT OK Maximum number of records returned per search request

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk HEC (write-back — disposition events) — Analyst writes back incident resolution outcomes
# ═══════════════════════════════════════════════════════════════════════════════
# Uses the identical HEC endpoint configured under the Gateway section; consumed by splunk_mcp.py to write resolution status logs.
# REQUIRED Must exactly match the SPLUNK_HEC_TOKEN value set in the Gateway section above
SPLUNK_HEC_TOKEN="b122039b-0000000000000000000003"
SPLUNK_HEC_VERIFY=0            # DEFAULT OK Same configuration as above

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Agent
# ═══════════════════════════════════════════════════════════════════════════════
POLL_INTERVAL=10               # DEFAULT OK Interval in seconds for Analyst to poll Splunk for new events

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Gateway Control — Analyst calls gateway /bans API endpoint to enforce blocks
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_HOST=localhost         # DEFAULT OK Gateway service address (localhost for single-machine deployments)
GATEWAY_PORT=3001              # DEFAULT OK Gateway service listening port
# OPTIONAL GATEWAY_API_KEY: Required only if authentication is enabled on the gateway
GATEWAY_API_KEY=
GATEWAY_USE_REAL=true          # DEFAULT OK true = push live block rules to gateway; false = simulate block operations

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Rule Engine
# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL RULES_PATH: Custom file path for rules.yaml; blank loads the file located in project root directory
RULES_PATH=
RULES_AUTO_RELOAD=true         # DEFAULT OK Hot-reload rule file on every rule lookup request

# ═══════════════════════════════════════════════════════════════════════════════
# CRM Agent
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_URL=http://localhost:3001       # DEFAULT OK Gateway endpoint where CRM Agent routes all control commands
SENTINEL_ENABLED=1                      # DEFAULT OK 1 = wrap all requests with security gateway inspection
AGENT_ID=crm-agent-01                   # DEFAULT OK Unique identifier for CRM Agent instance
SENTINEL_BLOCK_DETECTORS=injection,prompt_injection   # DEFAULT OK Detectors whose matches trigger immediate request blocking

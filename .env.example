# ── AI Sentinel Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables marked [Gateway] are for the security gateway module.
# Variables marked [Analyst] are for the analyst/agent module.
# Variables marked [CRM] are for the CMS Agent module.
# Variables marked [Shared] are used by multiple modules.

# ═══════════════════════════════════════════════════════════════════════════════
# Shared
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_ID=gateway-01
LLM_PROVIDER=anthropic
NO_PROXY=localhost,127.0.0.1
PYTHONUNBUFFERED=1

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: Splunk HEC (event emission)
# ═══════════════════════════════════════════════════════════════════════════════
# Both URL and TOKEN must be set for the gateway to actually send events.
# If unset, events are logged to stdout only (fail-soft).
# HEC URL 通常是 https://splunk:8088/services/collector 或 http://localhost:8088/services/collector
SPLUNK_HEC_URL=https://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
SPLUNK_HEC_VERIFY=0
SPLUNK_HEC_CHANNEL=
# Index the gateway writes events to. MUST match the Analyst's SPLUNK_DEFAULT_INDEX below.
SPLUNK_HEC_INDEX=main

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM Proxy (/v1/chat/completions)
# ═══════════════════════════════════════════════════════════════════════════════
# If both are set, /v1/chat/completions proxies to a real OpenAI-compatible endpoint.
# If unset, the proxy operates in simulated mode.
OPENAI_UPSTREAM_URL=
OPENAI_UPSTREAM_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM Semantic Detector (second-layer adjudication)
# ═══════════════════════════════════════════════════════════════════════════════
# 用 Claude 对规则层「拿不准」的输入（灰区命中/未命中）做语义裁决，补正则/关键词的盲区
# （语义变体越狱、间接注入、温和诱导）。
# 必填说明：LLM_DETECT_ENABLED=1 时 ANTHROPIC_API_KEY 为必填才能让语义层生效。
# 留空不报错——网关照常启动，语义层不生效（启动日志有一条 warning）。
# 运行期 fail-soft：单次调用超时/出错自动回退规则层结论，不阻断业务。
LLM_DETECT_ENABLED=1
# 必填（当 ENABLED=1）：Claude API Key，形如 sk-ant-...；留空则语义层不生效，网关照常启动
ANTHROPIC_API_KEY=
# 在线路径优先低延迟，默认 Haiku；复杂离线分析可换 claude-sonnet-4-6
LLM_DETECT_MODEL=claude-haiku-4-5
LLM_DETECT_TIMEOUT=8
LLM_DETECT_MAX_CHARS=6000
LLM_DETECT_CACHE_TTL=300
# 允许语义层对低危误报（如高熵串）降噪清除；默认关（仅升级，不降级，更安全）
LLM_DETECT_ALLOW_DEESCALATE=0
# 覆盖 Anthropic 端点（自托管/网关代理用），默认官方
ANTHROPIC_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk Search (REST API — reading events)
# ═══════════════════════════════════════════════════════════════════════════════
# Used by the Splunk Query MCP server for searching events.
# Set SPLUNK_USE_REAL=true to connect to a real Splunk instance.
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
SPLUNK_TOKEN=
SPLUNK_USE_REAL=true
SPLUNK_USE_SSL=false
SPLUNK_VERIFY_SSL=false
SPLUNK_DEFAULT_INDEX=main
SPLUNK_DEFAULT_EARLIEST=-30d
SPLUNK_MAX_RESULTS=1000

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk HEC (write-back — disposition events)
# ═══════════════════════════════════════════════════════════════════════════════
# Used by splunk_mcp.py for writing disposition status back to Splunk.
# Same HEC endpoint as the Gateway, but read by the Analyst for write operations.
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
SPLUNK_HEC_VERIFY=0

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Agent
# ═══════════════════════════════════════════════════════════════════════════════
POLL_INTERVAL=10

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Gateway Control
# ═══════════════════════════════════════════════════════════════════════════════
# Used by the Gateway Control MCP server for /bans API calls.
# Set GATEWAY_USE_REAL=true to send block commands to a real gateway.
GATEWAY_HOST=localhost
GATEWAY_PORT=3001
GATEWAY_API_KEY=
GATEWAY_USE_REAL=true

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Rule Engine
# ═══════════════════════════════════════════════════════════════════════════════
# Path to the shared rules.yaml file (auto-computed from project root if empty).
RULES_PATH=
RULES_AUTO_RELOAD=true

# ═══════════════════════════════════════════════════════════════════════════════
# CRM Agent
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_URL=http://localhost:3001
SENTINEL_ENABLED=1
AGENT_ID=crm-agent-01
SENTINEL_BLOCK_DETECTORS=injection,prompt_injection

# ── AI Sentinel Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables marked [Gateway] are for the security gateway module.
# Variables marked [Analyst] are for the analyst/agent module.
# Variables marked [Shared] are used by both modules.

# ── Shared ──────────────────────────────────────────────────────────────────
GATEWAY_ID=gateway-01
LLM_PROVIDER=anthropic

# ── Gateway: Splunk HEC ─────────────────────────────────────────────────────
# Both URL and TOKEN must be set for the gateway to actually send events.
# If unset, events are logged to stdout only (fail-soft).
# HEC URL 通常是 https://splunk:8088/services/collector 或 http://localhost:8088/services/collector
SPLUNK_HEC_URL=http://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=b122039b-c1bd-40ca-a16e-9873126b70a3
SPLUNK_HEC_VERIFY=0
SPLUNK_HEC_CHANNEL=

# ── Gateway: LLM Proxy ─────────────────────────────────────────────────────
# If set, /v1/chat/completions proxies to a real OpenAI-compatible endpoint.
OPENAI_UPSTREAM_URL=
OPENAI_UPSTREAM_KEY=

# ── Analyst: Splunk Search ──────────────────────────────────────────────────
# Used by the Splunk Query MCP server for searching events.
# Set SPLUNK_USE_REAL=true to connect to a real Splunk instance.
SPLUNK_HOST=localhost
SPLUNK_PORT=8000
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=hero54110
SPLUNK_TOKEN=
SPLUNK_USE_REAL=false
SPLUNK_USE_SSL=false
SPLUNK_VERIFY_SSL=false
SPLUNK_DEFAULT_INDEX=gateway_events
SPLUNK_DEFAULT_EARLIEST=-24h
SPLUNK_MAX_RESULTS=1000

# ── Analyst: Gateway Control ────────────────────────────────────────────────
# Used by the Gateway Control MCP server.
# Set GATEWAY_USE_REAL=true to send block commands to a real gateway.
GATEWAY_HOST=localhost
GATEWAY_PORT=3001
GATEWAY_API_KEY=
GATEWAY_USE_REAL=false

# ── Analyst: Rule Engine ────────────────────────────────────────────────────
# Path to the shared rules.yaml file (auto-computed if empty).
RULES_PATH=
RULES_AUTO_RELOAD=true

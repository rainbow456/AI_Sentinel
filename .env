# ── AI Sentinel Environment Variables ──────────────────────────────────────
# Variables marked [Gateway] are for the security gateway module.
# Variables marked [Analyst] are for the analyst/agent module.
# Variables marked [CRM] are for the CMS Agent module.
# Variables marked [Shared] are used by multiple modules.
#
# ┌─ 字段标注图例 / Legend ────────────────────────────────────────────────┐
# │ 【必填】   拿到代码后必须按你自己的环境填写/确认（连不上就是这些没对）   │
# │ 【可选】   可留空；留空即关闭对应功能，不影响主流程                      │
# │ 【默认即可】保持现值即可，一般无需修改                                   │
# └────────────────────────────────────────────────────────────────────────┘
#
# ⚠️ 重要：start_all.bat / start_all.ps1 启动时会用自己内置的同名变量
#    覆盖本文件的值（load_dotenv 不覆盖已存在的环境变量）。
#    若你用这两个脚本启动，请同步修改脚本里的对应值；
#    只有直接 `python -m gateway.main` / `python -m analyst.ui.app` 启动时，
#    本文件才是唯一配置来源。

# ═══════════════════════════════════════════════════════════════════════════════
# Shared
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_ID=gateway-01          # 【默认即可】网关实例标识
LLM_PROVIDER=anthropic         # 【默认即可】下游 LLM 提供方名称（仅打标用）
NO_PROXY=localhost,127.0.0.1   # 【默认即可】本地直连，绕开系统代理
PYTHONUNBUFFERED=1             # 【默认即可】实时刷日志

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: Splunk HEC (event emission) —— 网关把安全事件写入 Splunk
# ═══════════════════════════════════════════════════════════════════════════════
# URL 与 TOKEN 必须都正确，网关才会真正发事件；任一缺失则只打到 stdout（fail-soft）。
# 注意 scheme：HEC 监听 http 就写 http://，监听 https(自签) 就写 https:// 且把 VERIFY=0。
# 【必填】HEC 地址，按你的 Splunk 主机/端口/协议填，例：http://localhost:8088/services/collector
SPLUNK_HEC_URL="http://localhost:8088/services/collector"
# 【必填】HEC token —— 必须和 Splunk 端 Data Inputs → HTTP Event Collector 里的 token 一致
SPLUNK_HEC_TOKEN="00000000-0000-0000-0000-000000000000"
SPLUNK_HEC_VERIFY=0            # 【默认即可】1=校验 TLS 证书，自签证书填 0 跳过
SPLUNK_HEC_INDEX=main          # 【默认即可】网关事件写入的索引；与下方 Analyst 的 SPLUNK_DEFAULT_INDEX 必须一致
# 【可选】SPLUNK_HEC_CHANNEL：仅当 token 开了「索引确认」才需要；留空自动生成
SPLUNK_HEC_CHANNEL=

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM Proxy (/v1/chat/completions)
# ═══════════════════════════════════════════════════════════════════════════════
# 两者都填则 /v1/chat/completions 代理到真实 OpenAI 兼容后端；留空则走模拟模式。
# 【可选】上游 LLM 地址与 key，留空=模拟模式
OPENAI_UPSTREAM_URL=
OPENAI_UPSTREAM_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Gateway: LLM 语义检测（第二层裁决）—— 用 Claude 补正则/关键词的语义盲区
# ═══════════════════════════════════════════════════════════════════════════════
# 仅当规则层「拿不准」（灰区命中/未命中）时才调用 Claude，理解输入的真实意图，
# 捕捉正则漏掉的语义级攻击：语义变体越狱、间接注入、温和诱导、多轮渐进。
# 规则已可判拦的高危请求不会调用 LLM（省延迟省费用）；调用失败/超时一律回退规则层结论。
#
# 必填说明：LLM_DETECT_ENABLED=1 时，ANTHROPIC_API_KEY 为【必填】才能让语义层真正生效。
#    留空不会报错，网关照常启动，只是语义层不生效（启动日志会有一条 warning 提示）。
LLM_DETECT_ENABLED=1           # 【默认即可】1=启用语义层；0=关闭（关闭后下面的 key 无所谓）
# 【必填】Claude API Key（形如 sk-ant-...）。开关为 1 时需填；留空则语义层不生效，但网关照常启动。
ANTHROPIC_API_KEY=
LLM_DETECT_MODEL=claude-haiku-4-5   # 【默认即可】在线路径优先低延迟；离线复杂分析可换 claude-sonnet-4-6
LLM_DETECT_TIMEOUT=8           # 【默认即可】单次裁决超时（秒），超时即回退规则层结论
LLM_DETECT_MAX_CHARS=6000      # 【默认即可】送检文本截断长度，控延迟与费用
LLM_DETECT_CACHE_TTL=300       # 【默认即可】相同输入的裁决结果缓存秒数，去重省费用
# 【可选】1=允许语义层对低危误报（如高熵串）降噪清除；默认 0（仅升级不降级，更安全）
LLM_DETECT_ALLOW_DEESCALATE=0
# 【可选】ANTHROPIC_BASE_URL：覆盖 Claude 端点（自托管/代理用），留空=官方 api.anthropic.com
ANTHROPIC_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk Search (REST API — reading events) —— Analyst 从这里读事件
# ═══════════════════════════════════════════════════════════════════════════════
# 管理端口 8089 默认是 HTTPS（自签）。连不上多半是 HOST/账号密码/USE_SSL 没对。
SPLUNK_HOST=127.0.0.1          # 【必填】Splunk 主机，远程部署时改成实际 IP/域名
SPLUNK_PORT=8089               # 【必填】Splunk 管理(REST)端口，确认即可
SPLUNK_USERNAME=admin          # 【必填】Splunk 登录用户名
SPLUNK_PASSWORD=changeme      # 【必填】Splunk 登录密码（改成你自己的）
# 【可选】SPLUNK_TOKEN：用 Bearer token 认证时填；用账号密码则留空
SPLUNK_TOKEN=
SPLUNK_USE_REAL=true           # 【默认即可】true=连真实 Splunk；false=模拟数据
SPLUNK_USE_SSL=true            # 【必填】8089 是 https 填 true，是 http 填 false
SPLUNK_VERIFY_SSL=false        # 【默认即可】自签证书填 false 跳过校验
SPLUNK_DEFAULT_INDEX=main      # 【默认即可】Analyst 查询索引；必须与上方网关 SPLUNK_HEC_INDEX 一致
SPLUNK_DEFAULT_EARLIEST=-30d   # 【默认即可】默认搜索时间窗
SPLUNK_MAX_RESULTS=1000        # 【默认即可】单次搜索最大返回条数

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Splunk HEC (write-back — disposition events) —— Analyst 回写处置结果
# ═══════════════════════════════════════════════════════════════════════════════
# 与上面 Gateway 段同一个 HEC 端点；这里供 splunk_mcp.py 写回处置状态。
# 【必填】保持与上面 Gateway 段的 SPLUNK_HEC_TOKEN 完全一致
SPLUNK_HEC_TOKEN="00000000-0000-0000-0000-000000000000"
SPLUNK_HEC_VERIFY=0            # 【默认即可】同上

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Agent
# ═══════════════════════════════════════════════════════════════════════════════
POLL_INTERVAL=10               # 【默认即可】Analyst 轮询 Splunk 的间隔（秒）

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Gateway Control —— Analyst 调用网关 /bans 封禁接口
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_HOST=localhost         # 【默认即可】网关地址（同机默认 localhost）
GATEWAY_PORT=3001              # 【默认即可】网关端口
# 【可选】GATEWAY_API_KEY：网关若开启鉴权才需要填
GATEWAY_API_KEY=
GATEWAY_USE_REAL=true          # 【默认即可】true=向真实网关下发封禁；false=模拟

# ═══════════════════════════════════════════════════════════════════════════════
# Analyst: Rule Engine
# ═══════════════════════════════════════════════════════════════════════════════
# 【可选】RULES_PATH：自定义 rules.yaml 路径；留空=自动用项目根目录的
RULES_PATH=
RULES_AUTO_RELOAD=true         # 【默认即可】每次取规则时热重载

# ═══════════════════════════════════════════════════════════════════════════════
# CRM Agent
# ═══════════════════════════════════════════════════════════════════════════════
GATEWAY_URL=http://localhost:3001       # 【默认即可】CRM Agent 把命令路由到的网关地址
SENTINEL_ENABLED=1                      # 【默认即可】1=启用安全网关包装
AGENT_ID=crm-agent-01                   # 【默认即可】CRM Agent 标识
SENTINEL_BLOCK_DETECTORS=injection,prompt_injection   # 【默认即可】命中即拦截的检测器

# Local secrets — git-ignored, NOT committed. Fill in and you're connected.
# Empty host/password => safe fallback to bundled CSV data.

SPLUNK_USE_REAL=true

SPLUNK_HOST=
SPLUNK_PORT=

SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=

SPLUNK_USE_SSL=true
SPLUNK_VERIFY_SSL=false

# How far back the agent pulls events each cycle. Existing demo data is from
# 2026-06-07, so use a wide window to see it; set to -10m for true live mode.
SPLUNK_DEFAULT_EARLIEST=-30d
